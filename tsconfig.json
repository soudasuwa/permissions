{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "node",
		"strict": true,
		"rootDir": "src",
		"baseUrl": "src",
		"paths": {
			"@/*": ["*"],
			"@soudasuwa/permissions": ["./index"],
			"@soudasuwa/permissions/*": ["./*"]
		},
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"outDir": "dist",
		"declaration": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["src/**/*.test.ts"]
}
